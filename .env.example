# Application port (defaults to 5000 if unset)
PORT=5000

# The deployment environment (development | production)
NODE_ENV=production

# CORS Configuration
# In production, set this to your specific domain(s) for security
# Examples: https://yourdomain.com or https://yourdomain.com,https://www.yourdomain.com
# Use * only for development or if you need to allow all origins
CORS_ORIGIN=*

# Redis-backed room storage
# Leave REDIS_URL unset for local in-memory storage.
# Set this in production to persist room state across app restarts.
# Railway example: REDIS_URL=${{Redis.REDIS_URL}}
# REDIS_URL=redis://default:password@host:6379

# Room state TTL in seconds. Default: 14400 (4 hours)
ROOM_TTL_SECONDS=14400

# Redis per-room lock settings. Defaults are usually fine.
REDIS_LOCK_TTL_MS=5000
REDIS_LOCK_TIMEOUT_MS=2000
